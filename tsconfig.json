{
  "compilerOptions": {
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2024",
    "types": ["node"],
    "useUnknownInCatchVariables": true
